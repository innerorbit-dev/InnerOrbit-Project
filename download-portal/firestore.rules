rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Application Metadata (Public Read, Admin Write)
    // Used by the cross-platform update system
    match /app/version {
      allow read: if true;
      allow write: if false; // Managed via Firebase Admin SDK in publish_update.py
    }

    // Portal Metadata (Public)
    match /portal_passwords/{hash} { 
      allow get: if true; 
    }
    match /portal_access_logs/{logId} { 
      allow create: if true; 
    }
    
    // Default deny for all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
