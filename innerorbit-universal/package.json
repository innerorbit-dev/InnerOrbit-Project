{
  "name": "calcx",
  "version": "1.0.3",
  "description": "CalcX - Secure messaging app with stealth calculator mode (powered by InnerOrbit)",
  "main": "expo-router/entry",
  "author": "InnerOrbit",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web --output-dir dist && node scripts/fix-web-paths.js",
    "start:electron": "electron desktop/main.js",
    "electron:dev": "cross-env ELECTRON_START_URL=http://localhost:8081 electron desktop/main.js",
    "electron:build": "npm run build:web && electron-builder",
    "build:mac": "npm run build:web && electron-builder --mac",
    "build:linux": "npm run build:web && electron-builder --linux",
    "bump:patch": "node scripts/update-version.js patch",
    "bump:minor": "node scripts/update-version.js minor",
    "bump:major": "node scripts/update-version.js major",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build:android": "python ../tools/ops/build_apks.py",
    "manage": "python ../manager.py"
  },
  "dependencies": {
    "@noble/post-quantum": "^0.5.4",
    "electron-updater": "^6.7.3",
    "expo": "~54.0.33",
    "expo-background-task": "~1.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-screen-capture": "~8.0.9",
    "expo-sqlite": "~16.0.10",
    "expo-task-manager": "^14.0.9",
    "libsodium-wrappers": "^0.7.16",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-nitro-modules": "^0.35.1",
    "react-native-quick-crypto": "^1.0.16",
    "react-native-webrtc": "^124.0.7"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/outfit": "^0.4.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@tanstack/react-query": "^5.28.4",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.9.0",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^30.0.0",
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "^54.0.9",
    "cross-env": "^10.1.0",
    "crypto-js": "^4.2.0",
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "expo-application": "~7.0.8",
    "expo-auth-session": "~7.0.10",
    "expo-barcode-scanner-interface": "^3.0.0",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "^6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-font": "14.0.11",
    "expo-haptics": "^15.0.8",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-intent-launcher": "~13.0.8",
    "expo-keep-awake": "~15.0.8",
    "expo-linear-gradient": "^15.0.8",
    "expo-linking": "^8.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-media-library": "~18.2.1",
    "expo-module-scripts": "^55.0.2",
    "expo-modules-autolinking": "^3.0.24",
    "expo-network": "~8.0.8",
    "expo-notifications": "^0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "^31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.8.0",
    "fs-extra": "^11.3.3",
    "jest": "^29.7.0",
    "jest-expo": "^51.0.4",
    "path-browserify": "^1.0.1",
    "react-dom": "19.1.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.7.3",
    "react-native-worklets-core": "^1.6.2",
    "react-refresh": "^0.18.0",
    "typescript": "~5.9.2",
    "zustand": "^5.0.11"
  },
  "private": true,
  "build": {
    "appId": "com.innerorbit.calcx",
    "productName": "InnerOrbit",
    "compression": "maximum",
    "electronLanguages": [
      "en-US"
    ],
    "artifactName": "InnerOrbit-Setup-${version}.exe",
    "asar": true,
    "extraMetadata": {
      "main": "desktop/main.js",
      "firebaseUpdateUrl": "https://firebasestorage.googleapis.com/v0/b/innerorbit-bc8ce.firebasestorage.app/o/updates%2F"
    },
    "files": [
      "dist/**/*",
      "desktop/main.js",
      "desktop/preload.js",
      "assets/icon.png",
      "assets/favicon.png",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.messaging"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "icon": "assets/icon.png",
      "category": "Chat"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerHeader": "build/installerHeader.png",
      "installerSidebar": "build/installerSidebar.png",
      "include": "build/installer.nsh",
      "deleteAppDataOnUninstall": true
    }
  }
}
